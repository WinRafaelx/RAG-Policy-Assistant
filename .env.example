# The service runs locally without any external AI provider by default.
TTB_LOCAL_MODE=true
TTB_POLICIES_DIR=data/policies
TTB_RETRIEVAL_BACKEND=tfidf
TTB_RETRIEVAL_MIN_SCORE=0.08
TTB_DEFAULT_TOP_K=3
TTB_MAX_TOP_K=5
TTB_BOOTSTRAP_ON_STARTUP=false
TTB_EMBEDDING_MODEL=intfloat/multilingual-e5-base
TTB_EMBEDDING_DIMENSION=768
TTB_OLLAMA_BASE_URL=http://localhost:11434
TTB_OLLAMA_DEFAULT_MODEL=qwen3.5:4b
TTB_OLLAMA_TIMEOUT_SECONDS=30
TTB_OLLAMA_KEEP_ALIVE=5m
TTB_OLLAMA_NUM_PREDICT=80
TTB_OLLAMA_NUM_CTX=1024
TTB_OLLAMA_CONTEXT_TOP_K=1
TTB_RATE_LIMIT_PER_MINUTE=60
TTB_PROMPT_INJECTION_MODEL=ProtectAI/deberta-v3-base-prompt-injection
TTB_PROMPT_INJECTION_THRESHOLD=0.75
TTB_PROMPT_INJECTION_MALICIOUS_LABEL_PATTERN=injection|jailbreak|malicious|attack|unsafe|label_1
POSTGRES_PASSWORD=ttb_local_dev_password

# Required only when TTB_RETRIEVAL_BACKEND=pgvector.
TTB_DATABASE_URL=postgresql://ttb:${POSTGRES_PASSWORD}@localhost:5432/ttb_policy_assistant

# Optional future provider settings. Do not commit real secrets.
# OPENAI_API_KEY=
# AZURE_OPENAI_API_KEY=
# AZURE_OPENAI_ENDPOINT=
# AZURE_OPENAI_DEPLOYMENT=
