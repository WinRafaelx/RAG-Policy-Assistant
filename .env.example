# The service runs locally without any external AI provider by default.
TTB_LOCAL_MODE=true
TTB_POLICIES_DIR=policies
TTB_RETRIEVAL_BACKEND=tfidf
TTB_RETRIEVAL_MIN_SCORE=0.08
TTB_DEFAULT_TOP_K=3
TTB_MAX_TOP_K=5
TTB_BOOTSTRAP_ON_STARTUP=false
TTB_EMBEDDING_MODEL=intfloat/multilingual-e5-base
TTB_EMBEDDING_DIMENSION=768
TTB_OLLAMA_BASE_URL=http://localhost:11434
TTB_OLLAMA_DEFAULT_MODEL=qwen3.5:9b
TTB_OLLAMA_TIMEOUT_SECONDS=60
POSTGRES_PASSWORD=ttb_local_dev_password

# Required only when TTB_RETRIEVAL_BACKEND=pgvector.
TTB_DATABASE_URL=postgresql://ttb:${POSTGRES_PASSWORD}@localhost:5432/ttb_policy_assistant

# Optional future provider settings. Do not commit real secrets.
# OPENAI_API_KEY=
# AZURE_OPENAI_API_KEY=
# AZURE_OPENAI_ENDPOINT=
# AZURE_OPENAI_DEPLOYMENT=
